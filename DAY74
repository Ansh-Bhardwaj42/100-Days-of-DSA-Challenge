/*Problem Statement:Given an array of candidate names where each name represents a vote cast for that candidate, determine the 
candidate who received the maximum number of votes. In case of a tie, return the lexicographically smallest candidate name.*/

#include <stdio.h>
#include <string.h>

int main() {
    int n;

    // Taking number of votes
    printf("Enter number of votes: ");
    scanf("%d", &n);

    char names[n][50];

    // Taking candidate names
    printf("Enter the candidate names:\n");
    for(int i = 0; i < n; i++) {
        scanf("%s", names[i]);
    }

    // Displaying what user entered
    printf("\nYou entered:\n");
    for(int i = 0; i < n; i++) {
        printf("%s ", names[i]);
    }
    printf("\n");

    int maxVotes = 0;
    char winner[50];

    // Counting votes
    for(int i = 0; i < n; i++) {
        int count = 1;

        for(int j = i + 1; j < n; j++) {
            if(strcmp(names[i], names[j]) == 0) {
                count++;
            }
        }

        // Check for max votes
        if(count > maxVotes) {
            maxVotes = count;
            strcpy(winner, names[i]);
        }
        // Tie case → lexicographically smaller
        else if(count == maxVotes) {
            if(strcmp(names[i], winner) < 0) {
                strcpy(winner, names[i]);
            }
        }
    }

    // Output result
    printf("\nWinner: %s %d\n", winner, maxVotes);

    return 0;
}
