/*Problem Statement:Given a queue of integers, reverse the queue using a stack*/

#include <stdio.h>

#define MAX 100

int queue[MAX];
int front = -1, rear = -1;

int stack[MAX];
int top = -1;

// Queue functions
void enqueue(int value) {
    if (rear == MAX - 1) {
        printf("Queue Overflow\n");
        return;
    }

    if (front == -1)
        front = 0;

    queue[++rear] = value;
}

int dequeue() {
    if (front == -1 || front > rear) {
        printf("Queue Underflow\n");
        return -1;
    }

    return queue[front++];
}

// Stack functions
void push(int value) {
    if (top == MAX - 1) {
        printf("Stack Overflow\n");
        return;
    }

    stack[++top] = value;
}

int pop() {
    if (top == -1) {
        printf("Stack Underflow\n");
        return -1;
    }

    return stack[top--];
}

int main() {
    int n, i, x;

    printf("Enter number of elements in the queue: ");
    scanf("%d", &n);

    printf("Enter %d integers (these will be inserted into the queue):\n", n);
    for (i = 0; i < n; i++) {
        scanf("%d", &x);
        enqueue(x);
    }

    // Step 1: Move queue elements to stack
    while (front <= rear) {
        push(dequeue());
    }

    // Reset queue
    front = rear = -1;

    // Step 2: Move stack elements back to queue
    while (top != -1) {
        enqueue(pop());
    }

    // Print reversed queue
    printf("Reversed queue:\n");
    for (i = front; i <= rear; i++) {
        printf("%d ", queue[i]);
    }

    return 0;
}
