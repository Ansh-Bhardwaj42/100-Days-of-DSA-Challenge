/*Problem: Queue Using Array - Implement using linked list with dynamic memory allocation.*/

#include <stdio.h>
#include <stdlib.h>

// Node structure
struct node {
    int data;
    struct node *next;
};

struct node *front = NULL;
struct node *rear = NULL;

// Enqueue function
void enqueue(int value) {
    struct node *temp;

    temp = (struct node*)malloc(sizeof(struct node));
    temp->data = value;
    temp->next = NULL;

    if(front == NULL && rear == NULL) {
        front = rear = temp;
    }
    else {
        rear->next = temp;
        rear = temp;
    }
}

// Display queue
void display() {
    struct node *temp;

    if(front == NULL) {
        printf("Queue is empty");
        return;
    }

    temp = front;
    printf("Queue elements from front to rear:\n");

    while(temp != NULL) {
        printf("%d ", temp->data);
        temp = temp->next;
    }
}

int main() {
    int n, i, value;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    printf("Enter %d integers:\n", n);

    for(i = 0; i < n; i++) {
        scanf("%d", &value);
        enqueue(value);
    }

    display();

    return 0;
}
