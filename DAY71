/*Problem Statement-Implement a hash table using quadratic probing with formula:
h(k, i) = (h(k) + i*i) % m
*/

#include <stdio.h>
#include <string.h>

#define EMPTY -1

int table[100];

// Hash function
int hash(int key, int m) {
    return key % m;
}

// Insert using quadratic probing
void insert(int key, int m) {
    int i = 0;
    int index;

    while (i < m) {
        index = (hash(key, m) + i * i) % m;

        if (table[index] == EMPTY) {
            table[index] = key;
            return;
        }
        i++;
    }

    printf("Hash table is full\n");
}

// Search using quadratic probing
void search(int key, int m) {
    int i = 0;
    int index;

    while (i < m) {
        index = (hash(key, m) + i * i) % m;

        if (table[index] == key) {
            printf("FOUND\n");
            return;
        }

        if (table[index] == EMPTY) {
            break;
        }

        i++;
    }

    printf("NOT FOUND\n");
}

int main() {
    int m, n;
    char operation[10];
    int key;

    // Input table size
    scanf("%d", &m);

    // Initialize table
    for (int i = 0; i < m; i++) {
        table[i] = EMPTY;
    }

    // Input number of operations
    scanf("%d", &n);

    // Perform operations
    for (int i = 0; i < n; i++) {
        scanf("%s %d", operation, &key);

        if (strcmp(operation, "INSERT") == 0) {
            insert(key, m);
        } else if (strcmp(operation, "SEARCH") == 0) {
            search(key, m);
        }
    }

    return 0;
}
