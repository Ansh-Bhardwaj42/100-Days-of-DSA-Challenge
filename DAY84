/*Problem: Implement Insertion Sort - Implement the algorithm.*/

#include <stdio.h>

int main() {
    int n, i, j, key;

    // Step 1: Take size of array
    printf("Enter number of elements: ");
    scanf("%d", &n);

    int arr[n];

    // Step 2: Take array elements
    printf("Enter %d elements:\n", n);
    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Step 3: Insertion Sort logic
    for(i = 1; i < n; i++) {
        key = arr[i];
        j = i - 1;

        // Shift elements greater than key
        while(j >= 0 && arr[j] > key) {
            arr[j + 1] = arr[j];
            j--;
        }

        arr[j + 1] = key;
    }

    // Step 4: Print sorted array
    printf("Sorted array:\n");
    for(i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}
