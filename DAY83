/*Problem: Implement Selection Sort - Implement the algorithm.*/

#include <stdio.h>

int main() {
    int n, i, j, min_index, temp;

    // Step 1: Take size of array
    printf("Enter number of elements: ");
    scanf("%d", &n);

    int arr[n];

    // Step 2: Take array elements
    printf("Enter %d elements:\n", n);
    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Step 3: Selection Sort logic
    for(i = 0; i < n - 1; i++) {
        min_index = i;

        for(j = i + 1; j < n; j++) {
            if(arr[j] < arr[min_index]) {
                min_index = j;
            }
        }

        // Swap
        temp = arr[i];
        arr[i] = arr[min_index];
        arr[min_index] = temp;
    }

    // Step 4: Print sorted array
    printf("Sorted array:\n");
    for(i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}
