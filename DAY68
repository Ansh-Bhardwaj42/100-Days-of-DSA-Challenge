/*Problem: Implement topological sorting using in-degree array and queue (Kahnâ€™s Algorithm).*/

#include <stdio.h>
#define MAX 100

int main() {
    int n, e;
    int adj[MAX][MAX] = {0};
    int indegree[MAX] = {0};
    int queue[MAX], front = 0, rear = 0;
    int i, j, u, v;

    // Input number of vertices and edges
    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter number of edges: ");
    scanf("%d", &e);

    // Input edges
    printf("Enter edges (u v) meaning u -> v:\n");
    for(i = 0; i < e; i++) {
        scanf("%d %d", &u, &v);
        adj[u][v] = 1;
    }

    // Calculate indegree of each vertex
    for(i = 0; i < n; i++) {
        for(j = 0; j < n; j++) {
            if(adj[j][i] == 1) {
                indegree[i]++;
            }
        }
    }

    // Push vertices with indegree 0 into queue
    for(i = 0; i < n; i++) {
        if(indegree[i] == 0) {
            queue[rear++] = i;
        }
    }

    printf("Topological Order: ");

    int count = 0;

    while(front < rear) {
        int node = queue[front++];
        printf("%d ", node);
        count++;

        // Reduce indegree of adjacent nodes
        for(i = 0; i < n; i++) {
            if(adj[node][i] == 1) {
                indegree[i]--;
                if(indegree[i] == 0) {
                    queue[rear++] = i;
                }
            }
        }
    }

    // If count != n, graph has a cycle
    if(count != n) {
        printf("\nCycle detected! Topological sort not possible.\n");
    }

    return 0;
}
