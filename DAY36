/*Problem: Circular Queue Using Array - Implement using linked list with dynamic memory allocation.*/

#include <stdio.h>

#define MAX 100

int queue[MAX];
int front = -1, rear = -1;
int n;   // number of elements

// Enqueue operation
void enqueue(int value) {
    if ((rear + 1) % n == front) {
        printf("Queue is Full\n");
        return;
    }

    if (front == -1) {
        front = 0;
        rear = 0;
    } else {
        rear = (rear + 1) % n;
    }

    queue[rear] = value;
}

// Dequeue operation
void dequeue() {
    if (front == -1) {
        printf("Queue is Empty\n");
        return;
    }

    if (front == rear) {
        front = rear = -1;
    } else {
        front = (front + 1) % n;
    }
}

// Display queue
void display() {
    if (front == -1) {
        printf("Queue is Empty");
        return;
    }

    int i = front;
    while (1) {
        printf("%d ", queue[i]);
        if (i == rear)
            break;
        i = (i + 1) % n;
    }
}

int main() {
    int m, value;

    printf("Enter number of elements to enqueue: ");
    scanf("%d", &n);

    printf("Enter %d elements:\n", n);
    for (int i = 0; i < n; i++) {
        scanf("%d", &value);
        enqueue(value);
    }

    printf("Enter number of dequeue operations: ");
    scanf("%d", &m);

    for (int i = 0; i < m; i++) {
        dequeue();
    }

    // Circular behavior: add removed elements again
    for (int i = 0; i < m; i++) {
        enqueue(queue[i]);
    }

    printf("Queue elements from front to rear:\n");
    display();

    return 0;
}
