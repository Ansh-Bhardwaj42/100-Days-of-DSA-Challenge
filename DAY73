/*Problem Statement-Given a string s consisting of lowercase English letters, find and return the first character that does
not repeat in the string. If all characters repeat, return '$'.*/

#include <stdio.h>
#include <string.h>

int main() {
    char str[1000];
    int freq[26] = {0};  // To store frequency of each character

    // Taking input from user
    printf("Enter a string (lowercase letters only): ");
    scanf("%s", str);

    // Step 1: Count frequency of each character
    for (int i = 0; str[i] != '\0'; i++) {
        freq[str[i] - 'a']++;
    }

    // Step 2: Find first non-repeating character
    for (int i = 0; str[i] != '\0'; i++) {
        if (freq[str[i] - 'a'] == 1) {
            printf("First non-repeating character: %c\n", str[i]);
            return 0;
        }
    }

    // Step 3: If all characters repeat
    printf("First non-repeating character: $\n");

    return 0;
}
