/*Problem: Implement Binary Search Iterative - Implement the algorithm.*/

#include <stdio.h>

// Function for Binary Search (Iterative)
int binarySearch(int arr[], int n, int target) {
    int low = 0, high = n - 1;

    while (low <= high) {
        int mid = (low + high) / 2;

        if (arr[mid] == target)
            return mid;  // element found
        else if (arr[mid] < target)
            low = mid + 1;
        else
            high = mid - 1;
    }

    return -1; // element not found
}

// Function to sort array (Simple Bubble Sort)
void sortArray(int arr[], int n) {
    for(int i = 0; i < n - 1; i++) {
        for(int j = 0; j < n - i - 1; j++) {
            if(arr[j] > arr[j + 1]) {
                int temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
}

int main() {
    int n;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    int arr[n];

    // Taking input
    printf("Enter %d elements:\n", n);
    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Showing user input
    printf("\nYou entered: ");
    for(int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }

    // Sorting the array
    sortArray(arr, n);

    // Display sorted array
    printf("\nSorted array: ");
    for(int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }

    // Taking element to search
    int target;
    printf("\nEnter element to search: ");
    scanf("%d", &target);

    // Binary Search
    int result = binarySearch(arr, n, target);

    if(result != -1)
        printf("Element found at index %d\n", result);
    else
        printf("Element not found\n");

    return 0;
}
