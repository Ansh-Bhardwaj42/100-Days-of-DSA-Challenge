/*Problem: Sort array of non-negative integers using counting sort.Find max, build freq array, compute prefix sums, build output.*/

#include <stdio.h>

// Function to perform Counting Sort
void countingSort(int arr[], int n) {
    int i;

    // Step 1: Find maximum element
    int max = arr[0];
    for (i = 1; i < n; i++) {
        if (arr[i] > max)
            max = arr[i];
    }

    // Step 2: Create frequency array
    int count[max + 1];

    // Initialize count array to 0
    for (i = 0; i <= max; i++) {
        count[i] = 0;
    }

    // Store frequencies
    for (i = 0; i < n; i++) {
        count[arr[i]]++;
    }

    // Step 3: Compute prefix sums
    for (i = 1; i <= max; i++) {
        count[i] += count[i - 1];
    }

    // Step 4: Build output array (stable)
    int output[n];
    for (i = n - 1; i >= 0; i--) {
        output[count[arr[i]] - 1] = arr[i];
        count[arr[i]]--;
    }

    // Copy output back to original array
    for (i = 0; i < n; i++) {
        arr[i] = output[i];
    }
}

int main() {
    int n;

    // Input
    printf("Enter number of elements: ");
    scanf("%d", &n);

    int arr[n];

    printf("Enter %d non-negative elements:\n", n);
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Show user input
    printf("\nYou entered: ");
    for (int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }

    // Sorting
    countingSort(arr, n);

    // Output
    printf("\nSorted array: ");
    for (int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}
