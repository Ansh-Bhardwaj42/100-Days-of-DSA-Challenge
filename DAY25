/*Problem: Count Occurrences of an Element in Linked List - Implement using linked list with dynamic memory allocation*/

#include <stdio.h>
#include <stdlib.h>

// Define structure for linked list node
struct Node {
    int data;
    struct Node* next;
};

int main() {
    int n, i, key, count = 0;
    struct Node *head = NULL, *temp = NULL, *newNode = NULL;

    // Ask user for number of nodes
    printf("Enter number of nodes: ");
    scanf("%d", &n);

    // Ask user to enter elements
    printf("Enter %d elements:\n", n);

    for(i = 0; i < n; i++) {
        newNode = (struct Node*)malloc(sizeof(struct Node));

        scanf("%d", &newNode->data);
        newNode->next = NULL;

        if(head == NULL) {
            head = newNode;   // First node
        } else {
            temp->next = newNode;  // Link previous node
        }
        temp = newNode;
    }

    // Ask user for key
    printf("Enter element to count: ");
    scanf("%d", &key);

    // Traverse linked list to count occurrences
    temp = head;
    while(temp != NULL) {
        if(temp->data == key) {
            count++;
        }
        temp = temp->next;
    }

    // Print result
    printf("Number of occurrences of %d is: %d\n", key, count);

    return 0;
}
