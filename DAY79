/*Problem Statement:Find shortest distances from source vertex in a weighted graph with non-negative weights.*/

#include <stdio.h>
#include <limits.h>

#define MAX 100

int n, m;
int adj[MAX][MAX];

// Function to find minimum distance vertex
int minDistance(int dist[], int visited[]) {
    int min = INT_MAX, min_index = -1;

    for(int i = 1; i <= n; i++) {
        if(visited[i] == 0 && dist[i] < min) {
            min = dist[i];
            min_index = i;
        }
    }
    return min_index;
}

// Dijkstra function
void dijkstra(int source) {
    int dist[MAX], visited[MAX];

    // Initialize distances
    for(int i = 1; i <= n; i++) {
        dist[i] = INT_MAX;
        visited[i] = 0;
    }

    dist[source] = 0;

    for(int count = 1; count <= n - 1; count++) {
        int u = minDistance(dist, visited);
        visited[u] = 1;

        for(int v = 1; v <= n; v++) {
            if(!visited[v] && adj[u][v] && dist[u] != INT_MAX
               && dist[u] + adj[u][v] < dist[v]) {
                dist[v] = dist[u] + adj[u][v];
            }
        }
    }

    // Print distances
    printf("Shortest distances from source %d:\n", source);
    for(int i = 1; i <= n; i++) {
        printf("%d ", dist[i]);
    }
}

// Main
int main() {
    int u, v, w, source;

    printf("Enter number of vertices and edges: ");
    scanf("%d %d", &n, &m);

    // Initialize adjacency matrix
    for(int i = 1; i <= n; i++) {
        for(int j = 1; j <= n; j++) {
            adj[i][j] = 0;
        }
    }

    printf("Enter edges (u v w):\n");
    for(int i = 0; i < m; i++) {
        scanf("%d %d %d", &u, &v, &w);
        adj[u][v] = w;
        adj[v][u] = w; // undirected graph
    }

    printf("Enter source vertex: ");
    scanf("%d", &source);

    dijkstra(source);

    return 0;
}
