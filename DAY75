/*Problem Statement:Given an array of integers containing both positive and negative values, find the length of the longest 
contiguous subarray whose sum is equal to zero.*/

#include <stdio.h>

int main() {
    int n, i;

    // Ask user for size
    printf("Enter number of elements: ");
    scanf("%d", &n);

    int arr[n];

    // Input elements
    printf("Enter the elements:\n");
    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Print user input
    printf("\nYou entered: ");
    for(i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }

    int max_len = 0;

    // Logic to find longest subarray with sum 0
    for(int i = 0; i < n; i++) {
        int sum = 0;

        for(int j = i; j < n; j++) {
            sum += arr[j];

            if(sum == 0) {
                int length = j - i + 1;
                if(length > max_len) {
                    max_len = length;
                }
            }
        }
    }

    // Output result
    printf("\n\nLength of longest subarray with sum 0 = %d\n", max_len);

    return 0;
}
