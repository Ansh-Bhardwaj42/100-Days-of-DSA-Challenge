/*Problem: Find the integer square root of a given non-negative integer using Binary Search. The integer square root of 
a number is defined as the greatest integer whose square is less than or equal to the given number.*/

#include <stdio.h>

int integerSquareRoot(int n) {
    int low = 0, high = n;
    int ans = 0;

    while (low <= high) {
        int mid = (low + high) / 2;

        // To avoid overflow, use long long
        long long square = (long long)mid * mid;

        if (square == n) {
            return mid; // exact square root
        }
        else if (square < n) {
            ans = mid;      // store possible answer
            low = mid + 1;  // search right half
        }
        else {
            high = mid - 1; // search left half
        }
    }

    return ans; // largest integer whose square <= n
}

int main() {
    int n;

    printf("Enter a non-negative integer: ");
    scanf("%d", &n);

    printf("You entered: %d\n", n);

    int result = integerSquareRoot(n);

    printf("Integer square root of %d is: %d\n", n, result);

    return 0;
}
